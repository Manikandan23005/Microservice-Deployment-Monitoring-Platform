# --- DevOps Nexus Core Platform Configs ---
PORT=8000
LOG_LEVEL=info

# --- Observability Stack Integration ---
PROMETHEUS_URL=http://prometheus-service.devops-nexus.svc.cluster.local:9090
LOKI_URL=http://loki-service.devops-nexus.svc.cluster.local:3100

# --- Continuous Delivery ---
ARGOCD_SERVER=argocd-server.argocd.svc.cluster.local
ARGOCD_TOKEN=my-argocd-token-placeholder

# --- AI Diagnostics Service ---
# Configurable providers: "ollama", "openai", "groq", "lmstudio"
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OLLAMA_HOST=http://localhost:11434
LMSTUDIO_HOST=http://localhost:1234/v1

# --- Cache Database ---
REDIS_URL=redis://localhost:6379/0
